# ================================================================
# itda — 로컬 환경변수 예시 (.env.local.example)
# cp .env.local.example .env.local 후 실제 값 입력
# ================================================================

# Supabase 프로젝트 URL (Supabase 대시보드 > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://ayepxdoshnmxzfdxyztp.supabase.co

# Supabase Anon Key (공개 가능)
NEXT_PUBLIC_SUPABASE_ANON_KEY=여기에_anon_key_입력

# Supabase Service Role Key (절대 공개 금지 — 서버 전용)
SUPABASE_SERVICE_ROLE_KEY=여기에_service_role_key_입력

# 앱 URL (로컬: http://localhost:3000 / 배포: https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
