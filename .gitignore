# ================================================================
# itda — .gitignore
# ================================================================

# ── 환경변수 (절대 GitHub에 올리면 안 됨) ─────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Next.js 빌드 결과물 ────────────────────────────────────────
.next/
out/
build/

# ── 의존성 ─────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── TypeScript ─────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── 로그 ───────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── 에디터 ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── macOS ──────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── 테스트/커버리지 ────────────────────────────────────────────
coverage/
.nyc_output

# ── Vercel ─────────────────────────────────────────────────────
.vercel

# ── 기타 ───────────────────────────────────────────────────────
*.zip
*.tar.gz
