{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["icn1"],
  "functions": {
    "app/api/admin/manual/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/accrue-leave",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/attendance-checkin-remind",
      "schedule": "50 23 * * 0-4"
    },
    {
      "path": "/api/cron/attendance-checkout-remind",
      "schedule": "0 10 * * 1-5"
    }
  ]
}
