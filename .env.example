# ================================================================
# itda 급여관리 SaaS — 환경변수 예시
# 이 파일을 .env.local로 복사하고 실제 값을 입력하세요
# cp .env.example .env.local
# ================================================================

# ── Supabase ─────────────────────────────────────────────────
# Supabase 프로젝트 대시보드 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Service Role Key (서버 전용) ──────────────────────────────
# ⚠️ 절대 클라이언트에 노출 금지 / GitHub에 올리지 마세요
# Supabase > Settings > API > service_role 키
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── 앱 URL ───────────────────────────────────────────────────
# 로컬: http://localhost:3000
# 배포: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
